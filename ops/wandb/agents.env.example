WINGBEAT_REPO=/path/to/MosSongPlus
WINGBEAT_LAUNCH_QUEUE=wingbeat-training
WINGBEAT_DATASET_DIR=/srv/wingbeat/dataset
WINGBEAT_RUNTIME_ROOT=/srv/wingbeat/runtime
WINGBEAT_CACHE_DIR=/srv/wingbeat/runtime/dataset/.tf_cache
WINGBEAT_DATASET_MANIFEST=/srv/wingbeat/dataset/dataset-manifest.json
WINGBEAT_DATASET_MANIFEST_SHA256=replace-with-approved-sha256
WINGBEAT_STAGING_ROOT=/srv/wingbeat/runtime
WINGBEAT_ARTIFACT_DESTINATION="/srv/wingbeat/runtime"
# Leave blank on miru4090s; set user@host on compute-only machines.
WINGBEAT_ARTIFACT_OWNER=
WINGBEAT_ARTIFACT_POLL_SECONDS=30
